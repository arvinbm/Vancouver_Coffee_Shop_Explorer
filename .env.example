# Root .env — read by Docker Compose to inject variables into containers.
# Copy this file to .env and fill in your values before running docker compose up.

# Google Maps JavaScript API key (used by the Vite frontend inside Docker)
VITE_GOOGLE_MAPS_API_KEY=your_google_maps_api_key_here

# JWT signing secret — change this to something long and random in production
JWT_SECRET=dev_secret_change_in_production

# Google OAuth 2.0 — create credentials at https://console.cloud.google.com/
# Authorised redirect URI to add in the console: http://localhost:4000/api/auth/google/callback
GOOGLE_CLIENT_ID=your_google_client_id_here
GOOGLE_CLIENT_SECRET=your_google_client_secret_here
GOOGLE_REDIRECT_URI=http://localhost:4000/api/auth/google/callback
FRONTEND_URL=http://localhost:5173
